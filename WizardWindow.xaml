<Window x:Class="BritanniaReborn.WizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Britannia Reborn — Configuración inicial"
        Width="780" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="10" BorderBrush="{StaticResource ColorOro}" BorderThickness="2"
            Background="{StaticResource ColorOscuro}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Banner superior -->
            <Image Grid.Row="0" Source="pack://application:,,,/Resources/banner.png" Stretch="UniformToFill" Height="180"/>

            <!-- Cuerpo -->
            <Grid Grid.Row="1" Margin="40,30,40,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="No tenemos detectado Ultima Online en tu sistema"
                           Foreground="{StaticResource ColorOro}"
                           FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="1"
                           Text="Britannia Reborn requiere los archivos del cliente Ultima Online oficial. Si no lo tienes, descárgalo gratis. Si ya lo tienes en otra ubicación, selecciónala."
                           Foreground="{StaticResource ColorGris}"
                           FontSize="13" TextWrapping="Wrap"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Margin="0,0,0,30"/>

                <StackPanel Grid.Row="2" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <Button Name="BtnDescargar" Width="380" Height="50" Margin="0,0,0,14"
                            Background="#4A2A6A" Foreground="{StaticResource ColorOro}"
                            BorderBrush="{StaticResource ColorOro}" BorderThickness="2"
                            FontSize="14" FontWeight="Bold" Cursor="Hand"
                            Click="BtnDescargar_Click">
                        Descargar Ultima Online (oficial gratis)
                    </Button>
                    <Button Name="BtnYaTengo" Width="380" Height="50" Margin="0,0,0,14"
                            Background="{StaticResource ColorPanel}" Foreground="{StaticResource ColorOro}"
                            BorderBrush="{StaticResource ColorOro}" BorderThickness="1"
                            FontSize="14" Cursor="Hand"
                            Click="BtnYaTengo_Click">
                        Ya tengo Ultima Online (seleccionar carpeta)
                    </Button>
                    <Button Name="BtnSalir" Width="380" Height="40"
                            Background="Transparent" Foreground="{StaticResource ColorGris}"
                            BorderBrush="#444444" BorderThickness="1"
                            FontSize="12" Cursor="Hand"
                            Click="BtnSalir_Click">
                        Salir
                    </Button>
                </StackPanel>

                <TextBlock Grid.Row="3"
                           Name="LblEstado"
                           Foreground="{StaticResource ColorPurpura}"
                           FontSize="11" HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </Grid>
        </Grid>
    </Border>
</Window>
